@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Beach SA</title>
  
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
  
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body {
            background-color: #212529; 
        }
        .card {
            border: 1px solid #343a40;
        }
        .text-turquoise {
            color: #0dcaf0 !important; 
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center" style="height: 100vh;">

    <div class="card shadow-lg bg-white" style="width: 100%; max-width: 410px; border-radius: 12px;">
        <div class="card-body p-4">
            
            
            <div class="text-center mb-3">
                <h2 class="fw-bold text-dark m-0">
                    <i class="bi bi-tsunami text-turquoise me-2"></i>Beach SA
                </h2>
                <span class="badge bg-secondary-subtle text-secondary border px-2 mt-1 small">Sistema de Reservaciones</span>
            </div>
            
            <h5 class="text-center text-muted mb-4 small fw-semibold text-uppercase" style="letter-spacing: 0.5px;">Inicio de Sesión</h5>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger p-2 small text-center border-0 mb-3 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-controller="Login" asp-action="Index" method="post">
                <div class="mb-3">
                    <label for="email" class="form-label small fw-bold text-secondary">
                        <i class="bi bi-envelope-fill me-1"></i> Correo Electrónico
                    </label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="ejemplo@correo.com" required />
                </div>
                
                <div class="mb-4">
                    <label for="password" class="form-label small fw-bold text-secondary">
                        <i class="bi bi-lock-fill me-1"></i> Contraseña
                    </label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>
                
             
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Ingresar al Sistema
                </button>
            </form>
            
        </div>
    </div>

</body>
</html>