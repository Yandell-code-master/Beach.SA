<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Beach SA</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp_MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        /* Ajuste para que el footer no flote feo en pantallas grandes */
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
        main {
            flex: 1;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        .nav-link {
            transition: color 0.2s ease-in-out;
        }
        .nav-link:hover {
            color: #0d6efd !important; /* Resaltado azul al pasar el mouse */
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand text-info" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tsunami me-2"></i>Beach SA
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" 
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-light px-3" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light px-3" asp-area="" asp-controller="Cliente" asp-action="Index">
                                <i class="bi bi-people-fill me-1"></i> Clientes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light px-3" asp-area="" asp-controller="Paquete" asp-action="Index">
                                <i class="bi bi-box-seam-fill me-1"></i> Paquetes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light px-3" asp-area="" asp-controller="Reservacion" asp-action="Index">
                                <i class="bi bi-calendar-check-fill me-1"></i> Reservaciones
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light px-3" asp-area="" asp-controller="Factura" asp-action="Index">
                                <i class="bi bi-receipt me-1"></i> Facturas
                            </a>
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center">
                        <a class="btn btn-outline-danger btn-sm px-3" asp-controller="Login" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i> Salir
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5 class-fade-in">
            @RenderBody()
        </main>
    </div>

  <footer class="bg-transparent border-top border-secondary border-opacity-10 py-3 text-muted mt-auto">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center small">
        <div>
            <span class="text-secondary">&copy; @DateTime.Now.Year - <strong class="text-light">Beach SA</strong></span>
            <span class="text-secondary opacity-50 mx-2">|</span>
            <span class="text-secondary opacity-75">Sede del Pacífico UCR</span>
        </div>
        <div class="mt-2 mt-md-0">
            
            <span class="badge bg-dark bg-opacity-50 text-light border border-secondary border-opacity-25 py-2 px-3">
                <i class="bi bi-shield-lock-fill text-info me-1"></i> JWT Activo
            </span>
        </div>
    </div>
</footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>