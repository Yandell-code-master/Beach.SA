@model List<WebApp_MVC.Models.Cliente>
@{
    ViewData["Title"] = "Mantenimiento de Clientes";
}

<style>
    body {
        background: linear-gradient(135deg, #0f1115 0%, #1a1d24 100%) !important;
        color: #f8f9fa !important;
    }
    .text-dark, h2, h5, .modal-title { color: #ffffff !important; }
    .text-muted { color: #a0aec0 !important; }

    /* Contenedor Translúcido de la Tabla */
    .glass-card {
        background: rgba(255, 255, 255, 0.02) !important;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
    }

    /* Tabla Estilizada */
    .table { color: #e2e8f0 !important; }
    
    /* FIX CRUCIAL PARA EL HOVER: Mantiene la visibilidad de los textos */
    .table-hover tbody tr:hover td {
        background-color: rgba(255, 255, 255, 0.05) !important;
        color: #ffffff !important;
    }
    
    /* Modales en Modo Oscuro */
    .modal-content {
        background-color: #1a1d24 !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #f8f9fa !important;
    }
    .form-control, .form-select {
        background-color: #2d3748 !important;
        border: 1px solid #4a5568 !important;
        color: #ffffff !important;
    }
    .form-control:focus, .form-select:focus {
        background-color: #2d3748 !important;
        color: #ffffff !important;
        border-color: #0dcaf0 !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.25) !important;
    }
</style>

<div class="container mt-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill text-info"></i> Catálogo de Clientes</h2>
        <button class="btn btn-info fw-bold shadow-sm text-dark" data-bs-toggle="modal" data-bs-target="#modalCliente">
            <i class="bi bi-plus-circle"></i> Registrar Cliente
        </button>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-lg mb-4" role="alert">
            <strong><i class="bi bi-exclamation-triangle-fill me-1"></i> Control de Validación:</strong> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive card glass-card shadow-lg p-3">
        <table class="table table-hover align-middle m-0">
            <thead class="table-dark">
                <tr class="border-secondary">
                    <th>Cédula</th>
                    <th>Tipo</th>
                    <th>Nombre Completo</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Dirección</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var cliente in Model)
                    {
                        <tr class="border-secondary border-opacity-20">
                            <td><strong class="text-info">@cliente.Cedula</strong></td>
                            <td>
                               
                                @if (cliente.TipoCedula == "Física" || cliente.TipoCedula == "01")
                                {
                                    <span class="badge bg-primary shadow-sm">Física</span>
                                }
                                else if (cliente.TipoCedula == "Jurídica" || cliente.TipoCedula == "02")
                                {
                                    <span class="badge bg-secondary shadow-sm">Jurídica</span>
                                }
                                else if (cliente.TipoCedula == "DIMEX" || cliente.TipoCedula == "03")
                                {
                                    <span class="badge bg-info text-dark shadow-sm">DIMEX</span>
                                }
                                else
                                {
                                    <span class="badge bg-dark border border-secondary shadow-sm">@cliente.TipoCedula</span>
                                }
                            </td>
                            <td class="text-white fw-semibold">@cliente.NombreCompleto</td>
                            <td>@cliente.Telefono</td>
                            <td>@cliente.Email</td>
                            <td class="small text-muted">@cliente.Direccion</td>
                            <td class="text-center">
                                <form asp-controller="Cliente" asp-action="Delete" method="post" onsubmit="return confirm('¿Seguro que desea eliminar este cliente?');" style="display:inline;">
                                    <input type="hidden" name="cedula" value="@cliente.Cedula" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger fw-semibold"><i class="bi bi-trash"></i> Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No hay clientes registrados en el sistema.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalCliente" tabindex="-1" aria-labelledby="modalClienteLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark border-bottom border-secondary text-white">
                <h5 class="modal-title" id="modalClienteLabel"><i class="bi bi-person-plus-fill text-info me-2"></i>Nuevo Registro de Cliente</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Cliente" asp-action="Create" method="post">
                <div class="modal-body">
                    <p class="text-muted small"><i class="bi bi-info-circle me-1"></i> Al ingresar la cédula, el sistema autocompletará el nombre utilizando la API de Gometa.</p>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Número de Cédula</label>
                        <input type="text" name="Cedula" class="form-control" placeholder="Ej: 112340567" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Teléfono</label>
                        <input type="text" name="Telefono" class="form-control" placeholder="Ej: 88888888" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Correo Electrónico</label>
                        <input type="email" name="Email" class="form-control" placeholder="Ej: cliente@correo.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Dirección Exacta</label>
                        <textarea name="Direccion" class="form-control" rows="2" placeholder="Provincia, Cantón, Distrito..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-dark bg-opacity-50 border-top border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-info text-dark fw-bold">Guardar Registro</button>
                </div>
            </form>
        </div>
    </div>
